# Notion OAuth (optional — only needed for OAuth flow)
NOTION_CLIENT_ID=your_client_id
NOTION_CLIENT_SECRET=secret_xxx
NOTION_REDIRECT_URI=http://localhost:3000/callback

# Notion API — use an internal integration token
# Create one at https://www.notion.so/my-integrations
NOTION_API_KEY=

# Notion Database IDs
# Create 4 databases in Notion and paste their IDs here
NOTION_TASKS_DB_ID=
NOTION_APPROVALS_DB_ID=
NOTION_SPRINT_DB_ID=
NOTION_REPORTS_DB_ID=

# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub — generate a PAT at https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
